# ------------------------------------------------------------
# AfrikOpen Space local/deployment environment configuration
# Copy this file to .env for local development.
# Never commit the real .env file.
# ------------------------------------------------------------

APP_ENV=development
SERVER_ADDR=:8080

# PostgreSQL
# DATABASE_URL is also supported as an alternative variable name.
POSTGRES_DSN=host=localhost port=5433 user=CHANGE_ME password=CHANGE_ME dbname=africandoers sslmode=disable
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m

# MongoDB
# MONGODB_URI is also supported as an alternative variable name.
MONGO_URI=mongodb://CHANGE_ME:CHANGE_ME@localhost:27017/?authSource=admin
MONGO_DATABASE=africandoers

# Security
# Generate with:
# openssl rand -base64 48
CSRF_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
COOKIE_SECURE=false
CSRF_TTL=12h

# Connection and request limits
DATABASE_CONNECT_TIMEOUT=10s
REQUEST_BODY_MAX_BYTES=12582912
MULTIPART_MEMORY_BYTES=2097152
